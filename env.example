# OpenAI
OPENAI_API_KEY=your-openai-key-here

# Google OAuth2 — create credentials at https://console.cloud.google.com/
# Application type: Web application
# Enable the "Google Tasks API" in the API Library
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Where Google sends the user after they approve access.
# Must be listed as an Authorized Redirect URI in the Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Where the backend redirects the browser after a successful OAuth exchange.
FRONTEND_URL=http://localhost:5173

# Allow OAuth2 over plain HTTP (local dev only — remove in production).
OAUTHLIB_INSECURE_TRANSPORT=1
